.container {
display: grid;
grid-template-columns: 1fr 1fr 1fr;
gap: 20px;
align-items: center;

}
.box img {
max-width: 100%;
height: auto;
border-radius: 5px;
padding:30px ;

}
.box {
background-color:#74787b;
padding: 60px;
border-radius: 10px;
text-align: center;
transition: transform 0.3s ease;
flex-direction: column;
}
button{
color: rgb(5, 1, 8);
border-radius: 5px;
background-color: #3f4346;
}
.box:hover {
transform: scale(1.05);
}
.box1 {
grid-column: 1 / 2;
grid-row: 1 / 2;
}
.box2 {
grid-column: 2 / 4;
grid-row: 1 / 2;
}
.box3 {
grid-column: 1 / 2;
grid-row: 2 / 3;
}
.box4 {
grid-column: 2 / 3;
grid-row: 2 / 3;
}
.box5 {
grid-column: 3 / 4;
grid-row: 2 / 3;
}
.box6 {
grid-column: 1 / 4;
grid-row: 3 / 4;
}



